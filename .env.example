# Database
DB_PASSWORD=your_secure_password_here

# JWT
JWT_SECRET_KEY=your_64_character_hex_secret_key_here

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# Frontend URL (for CORS and redirects)
FRONTEND_URL=http://localhost:3000

# Email (Gmail SMTP)
# For Gmail: Enable 2FA, then create App Password at https://myaccount.google.com/apppasswords
# For Mailtrap (testing): Use sandbox.smtp.mailtrap.io with port 2525
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_app_password_here
MAIL_FROM=your_email@gmail.com
