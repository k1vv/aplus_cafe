{
  "name": "aplus-cafe",
  "private": true,
  "version": "1.0.0",
  "description": "APlus Cafe - Full-stack cafe ordering and reservation system",
  "scripts": {
    "dev:web": "cd apps/web && npm run dev",
    "dev:api": "cd apps/api && ./mvnw spring-boot:run",
    "build:web": "cd apps/web && npm run build",
    "build:api": "cd apps/api && ./mvnw clean package -DskipTests",
    "install:web": "cd apps/web && npm install",
    "test:web": "cd apps/web && npm test",
    "lint:web": "cd apps/web && npm run lint"
  },
  "keywords": ["cafe", "ordering", "reservation", "spring-boot", "react"],
  "author": "",
  "license": "MIT"
}
