# ==============================================
# APlus Cafe Frontend - Environment Variables
# ==============================================
# For local development: Copy to .env.local
# For Vercel: Set these in the Environment Variables tab
# ==============================================

# ----------------------------------------------
# API URL - Your Render Backend URL
# ----------------------------------------------
# Local Development:
VITE_API_URL=http://localhost:8080/api

# Production (set this in Vercel):
# VITE_API_URL=https://aplus-cafe-api.onrender.com/api

# ----------------------------------------------
# STRIPE (Optional - for payments)
# Get publishable key from: https://dashboard.stripe.com/test/apikeys
# Note: This is the PUBLIC key (pk_test_...), safe for frontend
# ----------------------------------------------
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
