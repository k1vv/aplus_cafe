# Backend Environment Variables
# These need to be set in Render dashboard or your deployment platform

# ===========================================
# DATABASE (Neon PostgreSQL)
# ===========================================
# Get these from: https://neon.tech (after creating a database)
# Format: jdbc:postgresql://ep-xxx.region.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_URL=jdbc:postgresql://ep-xxx.region.aws.neon.tech/neondb?sslmode=require
SPRING_DATASOURCE_USERNAME=neondb_owner
SPRING_DATASOURCE_PASSWORD=your_neon_password

# ===========================================
# JWT SECRET
# ===========================================
# Generate a secure random string (at least 32 characters)
# You can use: openssl rand -base64 32
JWT_SECRET_KEY=your-super-secret-jwt-key-at-least-32-characters-long

# ===========================================
# STRIPE (Payment Processing)
# ===========================================
# Get these from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# ===========================================
# EMAIL (Choose one option)
# ===========================================

# Option 1: Mailtrap (Recommended for testing)
# Sign up at: https://mailtrap.io
MAIL_HOST=sandbox.smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=your_mailtrap_username
MAIL_PASSWORD=your_mailtrap_password
MAIL_FROM=noreply@aplus.cafe

# Option 2: Gmail (For production)
# Enable 2FA, then create App Password at: https://myaccount.google.com/apppasswords
# MAIL_HOST=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your.email@gmail.com
# MAIL_PASSWORD=your_app_password
# MAIL_FROM=your.email@gmail.com

# ===========================================
# FRONTEND URL (for CORS and email links)
# ===========================================
# Set this to your Vercel deployment URL
FRONTEND_URL=https://your-app.vercel.app
